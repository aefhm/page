{
  "@context": "https://schema.org/",
  "@type": "Recipe",
  "slug": "guacamole",
  "name": "Guacamole",
  "description": "Simple guacamole with avocado, seeded tomato, a little red onion, serrano, lime, cilantro, and kosher salt.",
  "datePublished": "2024-06-13",
  "recipeCuisine": "Mexican",
  "recipeCategory": "Food",
  "recipeYield": "1",
  "prepTime": "PT5M",
  "keywords": "avocado",
  "author": {
    "@type": "Person",
    "name": "Xi Zhang",
    "url": "https://xizhang.page"
  },
  "nutrition": {
    "@type": "NutritionInformation",
    "calories": "50 calories"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5",
    "reviewCount": "3"
  },
  "recipeIngredient": [
    "3 ripe avocados",
    "1 roma tomato, seeds removed",
    "1/4 red onion",
    "1 serrano pepper",
    "2 limes",
    "1/4 cup chopped cilantro",
    "kosher salt",
    "olive oil, optional"
  ],
  "recipeInstructions": [
    {
      "@type": "HowToStep",
      "text": "Cube the avocados, then mash them lightly, leaving some texture."
    },
    {
      "@type": "HowToStep",
      "text": "Remove the tomato seeds, then chop the tomato, red onion, cilantro, and serrano."
    },
    {
      "@type": "HowToStep",
      "text": "Mix everything together."
    },
    {
      "@type": "HowToStep",
      "text": "Juice the limes into the mixture."
    },
    {
      "@type": "HowToStep",
      "text": "Add kosher salt to taste."
    },
    {
      "@type": "HowToTip",
      "text": "Olive oil is optional; drizzle if the avocados are dry."
    },
    {
      "@type": "HowToTip",
      "text": "Add a small pinch of cumin."
    }
  ]
}
