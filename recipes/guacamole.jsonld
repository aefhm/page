  "slug": "guacamole",
  "name": "Guacamole",
  "description": "Simple guacamole with avocado, tomato, onion, jalapeño, lime, and cilantro.",
  "datePublished": "2024-06-13",
  "recipeCuisine": "Mexican",
  "recipeCategory": "Food",
