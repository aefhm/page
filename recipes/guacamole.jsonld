  "recipeIngredient": [
    "3 ripe avocados",
    "1 roma tomato",
    "1 red onion",
    "1 jalapeño",
    "2 limes",
    "cilantro"
  ],
  "recipeInstructions": [
    {
      "@type": "HowToStep",
      "text": "Cube the avocados."
    },
    {
      "@type": "HowToStep",
      "text": "Chop the onion, tomato, cilantro, and jalapeño."
    },
    {
      "@type": "HowToStep",
      "text": "Mix everything together."
    },
    {
      "@type": "HowToStep",
      "text": "Juice the limes into the mixture."
    },
    {
      "@type": "HowToStep",
      "text": "Add salt to taste."
    }
  ]
}
