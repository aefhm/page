{
  "@context": "https://schema.org/",
  "@type": "Recipe",
  "recipeInstructions": [
    {
      "@type": "HowToStep",
      "text": "Peel sweet potatoes."
    },
    {
      "@type": "HowToStep",
      "text": "Soften the sweet potatoes by steaming or microwaving, then make them into a paste."
    },
    {
      "@type": "HowToStep",
      "text": "Add glutinous rice powder to the paste and mix."
    },
    {
      "@type": "HowToStep",
      "text": "Add sweet red bean paste filling and shape into a bun."
    },
    {
      "@type": "HowToStep",
      "text": "Coat both sides of the bun with a dash of oil."
    },
    {
      "@type": "HowToStep",
      "text": "Preheat oven to 350-400 F."
    },
    {
      "@type": "HowToStep",
      "text": "Bake for 15 minutes, flipping halfway through."
    }
  ],
  "name": "Red Bean Buns",
  "description": "Red bean paste in sweet potato and glutinous rice buns.",
  "datePublished": "2019-11-05",
  "recipeCuisine": "Chinese",
  "recipeCategory": "Food",
  "keywords": "red bean paste, buns, glutinous rice",
