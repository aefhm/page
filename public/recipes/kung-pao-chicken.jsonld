{
  "@context": "https://schema.org/",
  "@type": "Recipe",
  "recipeInstructions": [
    {
      "@type": "HowToStep",
      "text": "Cut the chicken into cubes."
    },
    {
      "@type": "HowToStep",
      "text": "Dice the green onions, ginger, and garlic."
    },
    {
      "@type": "HowToStep",
      "text": "Cube the green peppers."
    },
    {
      "@type": "HowToStep",
      "text": "Prepare a 1:1 marinade of soy sauce and cooking wine with 1 teaspoon of sugar, roughly 1 cup total."
    },
    {
      "@type": "HowToStep",
      "text": "Marinate the chicken with all of the ginger and about half of the green onions in roughly 1/2 cup of the sauce.",
      "image": {
        "@type": "ImageObject",
        "contentUrl": "/images/kung-pao-chicken-1.webp",
        "caption": "Chicken with aromatics and sauce before marinating."
      }
    },
    {
      "@type": "HowToStep",
      "text": "Cook the peanuts in a bit of oil until brown with a little char on the skin, then remove them from the pan.",
      "image": {
        "@type": "ImageObject",
        "contentUrl": "/images/kung-pao-chicken-3.webp",
        "caption": "Peanuts browned with a little char before they come out of the pan."
      }
    },
    {
      "@type": "HowToStep",
      "text": "Coat the marinated chicken with starch powder."
    },
    {
      "@type": "HowToStep",
      "text": "Cook the chicken with a bit of oil and remove it as soon as it is done."
    },
    {
      "@type": "HowToStep",
      "text": "Cook the remaining green onions with the green peppers and garlic."
    },
    {
      "@type": "HowToStep",
      "text": "Add the chicken back briefly, then pour in about 1/2 cup of the soy sauce and cooking wine mixture and finish with salt and pepper."
    },
    {
      "@type": "HowToTip",
      "text": "Keep the sauce glossy rather than soupy. The chicken should stay tender and the peanuts should still taste toasty at the end."
    }
  ],
  "name": "Kung Pao Chicken",
  "description": "A quick stir-fry built around browned peanuts, glossy sauce, and just-cooked chicken.",
  "datePublished": "2019-11-05",
  "recipeCuisine": "Chinese",
  "recipeCategory": "Food",
  "keywords": "chicken, meat, peanuts",
  "author": {
    "@type": "Person",
    "name": "Xi Zhang",
    "url": "https://xizhang.page"
  },
  "image": {
    "@type": "ImageObject",
    "url": "/images/kung-pao-chicken-4.webp",
    "caption": "Finished plate of kung pao chicken with peanuts and green peppers"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5",
    "reviewCount": "1"
  },
  "recipeIngredient": [
    "1 lb of chicken",
    "3 green onions",
    "1 teaspoon sugar",
    "5 oz of raw, shelled peanuts with skin on",
    "3 - 5 slices of ginger",
    "5 cloves of garlic",
    "2 - 3 green peppers",
    "Tapioca or starch powder",
    "Cooking wine",
    "Soy sauce",
    "Red chili flakes"
  ]
}